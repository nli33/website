---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "My Personal Website" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-gray-100 text-gray-900">
		<header class="border-b border-gray-200 bg-white">
			<nav class="mx-auto flex w-full max-w-4xl items-center justify-between px-6 py-4">
				<a href="/" class="text-lg font-semibold">Neng Li</a>
				<div class="flex items-center gap-6 text-sm font-medium">
					<a href="/" class="text-gray-700 hover:text-gray-900">Home</a>
					<a href="/writing" class="text-gray-700 hover:text-gray-900">Writing</a>
				</div>
			</nav>
		</header>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>

---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Writing | Neng Li">
  <main class="mx-auto w-full max-w-4xl px-6 py-12">
    <h1 class="mb-2 text-4xl font-bold">Writing</h1>

    {
      posts.length === 0 ? (
        <p class="text-gray-600">No posts yet.</p>
      ) : (
        <ul class="space-y-6">
          {posts.map((post) => (
            <li class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <a
                href={`/writing/${post.slug}`}
                class="text-2xl font-semibold text-blue-700 hover:underline"
              >
                {post.data.title}
              </a>
              <p class="mt-2 text-gray-700">{post.data.description}</p>
              <p class="mt-3 text-sm text-gray-500">
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                  timeZone: "UTC",
                })}
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>
